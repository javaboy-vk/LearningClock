{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launcher: Learning Clock VBS",
      "type": "node-terminal",
      "request": "launch",
      "command": "wscript.exe //nologo \"${workspaceFolder}\\launcher\\Learning-clock.vbs\" \"${workspaceFolder}\\launcher\\dev.properties\"",
      "cwd": "${workspaceFolder}\\launcher",
      "presentation": {
        "group": "01-app",
        "order": 1
      }
    },
    {
      "name": "Python: Learning Clock GUI",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\src\\learningclock\\learning-clock.py",
      "args": [
        "--learning-path",
        "LearningClock",
        "--log-dir",
        "${workspaceFolder}\\build\\learning-clock-logs",
        "--debug-break-on-click",
        "--debug-break-on-close"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}\\src"
      },
      "console": "integratedTerminal",
      "justMyCode": true,
      "presentation": {
        "group": "01-app",
        "order": 2
      }
    },
    {
      "name": "Python: LearningClock module",
      "type": "debugpy",
      "request": "launch",
      "module": "learningclock",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}\\src"
      },
      "console": "integratedTerminal",
      "justMyCode": true,
      "presentation": {
        "group": "01-app",
        "order": 3
      }
    },
    {
      "name": "Python: Current file",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}\\src"
      },
      "console": "integratedTerminal",
      "justMyCode": true,
      "presentation": {
        "group": "02-tools",
        "order": 1
      }
    },
    {
      "name": "Launcher: Debug VBS Only",
      "type": "node-terminal",
      "request": "launch",
      "command": "cscript.exe //nologo //D //X \"${workspaceFolder}\\launcher\\Learning-clock.vbs\" \"${workspaceFolder}\\launcher\\vbs-debug.properties\"",
      "cwd": "${workspaceFolder}\\launcher",
      "presentation": {
        "group": "02-tools",
        "order": 2
      },
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Python: Diavgeia LearningPath GUI",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\src\\learningclock\\learning-clock.py",
      "args": [
        "--learning-path",
        "Diavgeia LearningPath",
        "--log-dir",
        "D:\\DiavgeiaVault\\Engineering\\LearningClock\\LearningPath",
        "--debug-break-on-close"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}\\src"
      },
      "console": "integratedTerminal",
      "justMyCode": true,
      "presentation": {
        "group": "01-app",
        "order": 4
      }
    },
    {
      "name": "Tests: Run CSV Regression File (prompts for CSV)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\tests\\test_learning_clock_csv_regression.py",
      "args": [
        "--properties",
        "${input:learningClockRegressionProperties}"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}\\tests;${workspaceFolder}\\src"
      },
      "console": "integratedTerminal",
      "justMyCode": true,
      "presentation": {
        "group": "03-tests",
        "order": 1
      }
    },
    {
      "name": "Tests: Run CSV Regression Test Index",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\tests\\test_learning_clock_csv_regression.py",
      "args": [
        "--properties",
        "${input:learningClockRegressionProperties}",
        "${input:learningClockCsvTestSelector}"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}\\tests;${workspaceFolder}\\src"
      },
      "console": "integratedTerminal",
      "justMyCode": true,
      "presentation": {
        "group": "03-tests",
        "order": 2
      }
    },
    {
      "name": "Tests: Debug CSV Regression Test1",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\tests\\test_learning_clock_csv_regression.py",
      "args": [
        "--properties",
        "${workspaceFolder}\\tests\\fixtures\\MAGPAI-regression.properties",
        "test1"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}\\tests;${workspaceFolder}\\src"
      },
      "console": "integratedTerminal",
      "justMyCode": false,
      "presentation": {
        "group": "03-tests",
        "order": 3
      }
    },
    {
      "name": "Tests: Debug CSV Regression File (prompts for CSV)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\tests\\test_learning_clock_csv_regression.py",
      "args": [
        "--properties",
        "${input:learningClockRegressionProperties}"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}\\tests;${workspaceFolder}\\src"
      },
      "console": "integratedTerminal",
      "justMyCode": false,
      "presentation": {
        "group": "03-tests",
        "order": 4
      }
    }
  ],
  "inputs": [
    {
      "id": "learningClockRegressionProperties",
      "type": "promptString",
      "description": "Path to the Learning Clock regression properties file",
      "default": "D:\\GitHub\\LearningClock\\tests\\fixtures\\MAGPAI-regression.properties"
    },
    {
      "id": "learningClockCsvTestSelector",
      "type": "promptString",
      "description": "CSV regression test index to run, such as test1, test2, test3, or test4",
      "default": "test1"
    }
  ]
}
